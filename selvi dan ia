  display:flex;
  justify-content:center;
  align-items:center;

  margin:-10px 0 30px 0;

  line-height:1;
}

/* COUNTDOWN */

.countdown{
  display:flex;
  justify-content:center;
  gap:25px;
  margin-top:50px;
  flex-wrap:wrap;
}

.time-box{
  width:120px;
  height:120px;
  border-radius:25px;
  background:white;
  box-shadow:0 10px 25px rgba(0,0,0,0.08);
  display:flex;
  flex-direction:column;
  justify-content:center;
}

.time-box h2{
  font-size:38px;
}

/* EVENT */

.event-card{
  background:white;
  padding:45px;
  border-radius:30px;
  margin:40px auto;
  max-width:560px;
  box-shadow:0 10px 30px rgba(0,0,0,0.08);

  line-height:2.1;
}

.event-card h2{
  margin-bottom:18px;
}

.event-card h4{
  margin-top:18px;
  margin-bottom:15px;
}

.location-btn{
  margin-top:28px;
}

.location-btn{
  display:inline-block;
  margin-top:25px;
  padding:14px 30px;
  background:#e9c5c5;
  color:white;
  border-radius:40px;
  text-decoration:none;
}

/* GALLERY */

.gallery-grid{
  margin-top:50px;
  display:grid;
  grid-template-columns:repeat(2,1fr);
  gap:22px;
  max-width:900px;
  margin-left:auto;
  margin-right:auto;
  padding:0 10px;
}

.gallery-wrapper{
  max-width:850px;

  margin:0 auto;
}

.gallery-grid img{
  width:100%;
  height:420px;
  object-fit:cover;
  border-radius:35px;

  box-shadow:0 10px 25px rgba(0,0,0,0.08);
}

.gallery-text{
  margin-top:25px;
  margin-bottom:45px;
  line-height:1.9;
}

/* STORY */

.story-image img{
  width:100%;
  max-width:500px;
  border-radius:35px;
  margin-bottom:50px;
}

.story-box{
  background:rgba(255,255,255,0.9);
  padding:35px;
  border-radius:30px;
  margin:30px auto;
  max-width:620px;
  box-shadow:0 10px 25px rgba(0,0,0,0.06);
  text-align:left;
}

.story-box h3{
  margin-bottom:15px;
  color:#c99797;
  text-align:center;
}

.story-box p{
  line-height: 2;
  font-size: 15px;
  text-align:justify;
  text-justify:inter-word;
  hyphens:auto;
  word-spacing:normal;
}

/* RSVP */

.stats{
  display:flex;
  justify-content:center;
  gap:70px;
  margin:40px 0;
}

.firebase-status{
  text-align:center;
  margin:18px auto 0;
  max-width:620px;
  font-size:14px;
  color:#6f6f6f;
}

.firebase-status.connected{
  color:#1f7a3f;
}

.firebase-status.error{
  color:#b02a30;
}

.wish-form{
  max-width:560px;
  margin:auto;
}

.wish-list{
  max-width:620px;

  margin:40px auto 0;
}

.wish-form input,
.wish-form textarea,
.wish-form select{
  width:100%;
  padding:18px;
  border:none;
  border-radius:20px;
  margin-bottom:18px;
  background:white;
  box-shadow:0 5px 20px rgba(0,0,0,0.05);
  font-family:'Montserrat',sans-serif;
  font-size:15px;
  color:#5d4a4a;
}

.wish-form textarea{
  min-height:140px;

  resize:none;
}

.wish-form button{
  width:100%;
  padding:18px;
  border:none;
  border-radius:20px;
  background:#dbaeb8;
  color:white;
  font-size:16px;
}

.wish-item{
  background:white;
  padding:25px;
  border-radius:25px;
  margin-top:20px;
  box-shadow:0 5px 20px rgba(0,0,0,0.05);
  text-align:left;
}

.story-box,
.event-card,
.bank-card,
.wish-item{
  border-radius:30px;
}

/* GIFT */

.gift-btn{
  padding:15px 35px;
  border:none;
  border-radius:40px;
  background:#dbaeb8;
  color:white;
  cursor:pointer;
}

.gift-text{
  margin-top:25px;
  margin-bottom:35px;

  line-height:2;

  max-width:700px;
  margin-left:auto;
  margin-right:auto;
}

.gift-btn{
  padding:15px 35px;
  border:none;
  border-radius:40px;
  background:#dbaeb8;
  color:white;
  cursor:pointer;

  margin-top:10px;
}

.gift-box{
  display:none;
  margin-top:30px;
}

.bank-card{
  background:white;
  padding:30px;
  border-radius:25px;
  margin:20px auto;
  max-width:450px;
  box-shadow:0 5px 20px rgba(0,0,0,0.05);
}

/* FOOTER */

.footer{
  padding-bottom:120px;

  line-height:2.2;
}

.footer .section-inner{
  max-width:700px;
  margin:0 auto;
  text-align:center;
}

.footer-text{
  max-width:760px;

  margin:0 auto;

  line-height:2.3;

  font-size:16px;

  color:#6f5b5b;
}

.footer h3{
  margin-top:28px;
  margin-bottom:25px;

  font-family:'Cormorant Garamond',serif;
}

.footer h2{
  margin-top:30px;
  margin-bottom:18px;

  font-family:'Cormorant Garamond',serif;
  font-size:42px;

  letter-spacing:1px;
}

.made{
  margin-top:60px;
  opacity:0.7;
}

/* MUSIC */

.music-btn{
  position:fixed;
  bottom:20px;
  right:20px;
  width:55px;
  height:55px;
  border:none;
  border-radius:50%;
  background:#dbaeb8;
  color:white;
  font-size:20px;
  z-index:999;
}

/* ANIMATION */

.reveal{
  opacity:0;
  transform:translateY(70px);

  transition:
    opacity 1.1s ease,
    transform 1.1s ease;

  will-change:transform, opacity;
}

.reveal.show{
  opacity:1;
  transform:translateY(0);
}

.left-show,
.right-show{
  opacity:0;

  transition:
  all 1.4s cubic-bezier(0.22,1,0.36,1);
}

.left-show{
  transform:translateX(-80px);
}

.right-show{
  transform:translateX(80px);
}

.left-show.show,
.right-show.show{
  opacity:1;

  transform:translateX(0);
}

.fade-up,
.left-show,
.right-show{
  will-change: transform, opacity;
}

/* SECTION COLORS */

.section-soft{
  background:#fff7f8;
}

.section-ivory{
  background:#fffdf8;
}

.section-pink{
  background:#fdecef;
}

.section-white{
  background:#ffffff;
}

.section-blush{
  background:#fff4f5;
}

.section-cream{
  background:#fffaf4;

  width: 100%;
}

img{
  max-width:100%;
  display:block;
}

/* MOBILE */

@media(max-width:768px){

  .hero-content{
    width:90%;
    padding:35px 24px;
    margin:20px;
    border-radius:28px;
  }

  .hero h1{
    font-size:50px;
    line-height:1.1;
  }

  .hero-subtitle{
    font-size:18px;
    letter-spacing:3px;
  }

  .guest-box h3{
    font-size:20px;
  }

  .section{
    padding:0 6%;
  }

  .section-inner{
    padding:90px 15px 100px;
  }

  .section-title{
    font-size:40px;
    margin-bottom:30px;
    width:100%;
    text-align:center;
  }

  .section-inner,
  .desc,
  .quotes,
  .ayat,
  .gift-text,
  .gallery-text,
  .footer-text,
  .couple-text,
  .event-card,
  .wish-item{
    text-align:center;
    font-size:15px;
    line-height:2;
  }

  .couple-box{
    flex-direction:column;
    gap:25px;
  }

  .couple-photo img{
    width:220px;
    height:300px;
  }

  .couple-text h2{
    font-size:32px;
  }

  .couple-text h4{
    font-size:22px;
  }

  .gallery-grid{
    grid-template-columns:repeat(2,1fr);
  }

  .gallery-grid img{
    height:220px;
  }

  .story-box p{
    line-height:2.1;
    text-align:justify;
  }

}
