import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-app.js";

import {
  getFirestore,
  collection,
  addDoc,
  onSnapshot,
  query,
  orderBy,
  serverTimestamp
} from "https://www.gstatic.com/firebasejs/10.12.2/firebase-firestore.js";

const firebaseConfig = {
  apiKey: "AIzaSyChVlyuRhA7UxXbxPcfNlx1BJrGJp6h6mw",
  authDomain: "wedding-f5a58.firebaseapp.com",
  projectId: "wedding-f5a58",
  storageBucket: "wedding-f5a58.firebasestorage.app",
  messagingSenderId: "105066052937",
  appId: "1:105066052937:web:6293a9e5dde3720ad1ee98"
};

const app = initializeApp(firebaseConfig);

const db = getFirestore(app);

document.addEventListener("DOMContentLoaded", () => {

if (window.location.protocol === 'file:') {
  console.warn('Firebasemodul mungkin tidak berjalan sempurna saat membuka file langsung. Jalankan lewat server lokal atau Firebase Hosting.');
}

console.log('Firebase initialized', firebaseConfig.projectId);

// LOCK SCROLL
function lockInitialScroll(){
  window.scrollTo(0,0);
  document.body.classList.add('lock-scroll');
}

lockInitialScroll();

window.addEventListener('pageshow', (event) => {
  if (event.persisted) {
    lockInitialScroll();
  }
});

// OPEN INVITATION
const openBtn = document.getElementById('openInvitation');
const hero = document.getElementById('hero');
const music = document.getElementById('bgMusic');


if(openBtn){

openBtn.addEventListener('click', () => {

  hero.classList.add('hide');

  document.body.classList.remove('lock-scroll');

  music.play();

});

}

// AUTO GUEST NAME
const urlParams = new URLSearchParams(window.location.search);
let guest = urlParams.get('to');

if (!guest) {
  const match = window.location.href.match(/[?&]to=([^&]+)/);
  if (match) {
    guest = decodeURIComponent(match[1].replace(/\+/g, ' '));
  }
}

if (guest) {
  document.getElementById('guestName').innerText = guest;
}

// COUNTDOWN
const targetDate = new Date("June 6, 2026 09:00:00").getTime();

setInterval(() => {

  const now = new Date().getTime();

  const distance = targetDate - now;

  const days = Math.floor(distance / (1000 * 60 * 60 * 24));

  const hours = Math.floor((distance % (1000 * 60 * 60 * 24))
  / (1000 * 60 * 60));

  const minutes = Math.floor((distance % (1000 * 60 * 60))
  / (1000 * 60));

  const seconds = Math.floor((distance % (1000 * 60))
  / 1000);

  document.getElementById('days').innerHTML = days;
  document.getElementById('hours').innerHTML = hours;
  document.getElementById('minutes').innerHTML = minutes;
  document.getElementById('seconds').innerHTML = seconds;

},1000);

// ANIMATION
const observer = new IntersectionObserver((entries, observer) => {
  entries.forEach((entry) => {
    if (entry.isIntersecting) {
      entry.target.classList.add('show');
      observer.unobserve(entry.target); // 🔥 ini penting
    }
  });
}, {
  threshold: 0.12
});

document.querySelectorAll('.reveal, .left-show, .right-show').forEach((el) => {
  observer.observe(el);
});

// RSVP
const form = document.getElementById('wishForm');
const wishList = document.getElementById('wishList');
const firebaseStatus = document.getElementById('firebaseStatus');

const wishesRef = collection(db, "wishes");

if (!form || !wishList) {
  console.error('Elemen RSVP tidak ditemukan:', { form, wishList });
}

const setFirebaseStatus = (text, state) => {
  if (!firebaseStatus) return;
  firebaseStatus.textContent = text;
  firebaseStatus.classList.remove('connected', 'error');
  if (state) firebaseStatus.classList.add(state);
};

setFirebaseStatus('Memeriksa koneksi Firebase...', 'connected');

form?.addEventListener('submit', async (e) => {
  e.preventDefault();

  const name = document.getElementById('name').value.trim();
  const message = document.getElementById('message').value.trim();
  const attendance = document.getElementById('attendance').value;

  try {
    await addDoc(wishesRef, {
      name,
      message,
      attendance,
      createdAt: serverTimestamp()
    });

    console.log('Reservasi tersimpan:', { name, attendance });
    setFirebaseStatus('Reservasi berhasil disimpan.', 'connected');
    form.reset();
  } catch (error) {
    console.error('Gagal menyimpan reservasi:', error);
    setFirebaseStatus('Gagal menyimpan reservasi. Periksa koneksi atau Firebase.', 'error');
    alert('Gagal menyimpan reservasi. Periksa koneksi atau pengaturan Firebase.');
  }
});

try {

  onSnapshot(

    query(wishesRef),

    (snapshot) => {

      wishList.innerHTML = "";

      let hadir = 0;
      let tidakHadir = 0;

      snapshot.forEach((doc) => {

        const data = doc.data();

        if(data.attendance === 'Hadir'){
          hadir++;
        } else {
          tidakHadir++;
        }

        const div = document.createElement('div');

        div.classList.add('wish-item');

        div.innerHTML = `
          <h3>${data.name}</h3>
          <p>${data.message}</p>
          <small>${data.attendance}</small>
        `;

        wishList.appendChild(div);

      });

      document.getElementById('hadirCount').innerHTML = hadir;

      document.getElementById('tidakHadirCount').innerHTML = tidakHadir;

    }

  );

} catch(error){

  console.error(error);

}

// GIFT
const giftBtn = document.getElementById('giftBtn');
const giftBox = document.getElementById('giftBox');

giftBtn.addEventListener('click',()=>{

  if(giftBox.style.display === 'block'){
    giftBox.style.display = 'none';
  }else{
    giftBox.style.display = 'block';
  }

});

// MUSIC BUTTON
const musicBtn = document.getElementById('musicBtn');

if(musicBtn){

musicBtn.addEventListener('click',()=>{

  if(music.paused){
    music.play();
  }else{
    music.pause();
  }

});

}

console.log("Firebase RSVP Connected");

});
